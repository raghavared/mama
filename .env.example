# MAMA System — Environment Configuration Template
# Copy this to .env and fill in real values. NEVER commit .env to git.

# === LLM ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Image Generation ===
OPENAI_API_KEY=your_openai_api_key_here

# === Video Generation ===
VEO3_API_KEY=your_veo3_api_key_here
KLING_API_KEY=your_kling_api_key_here
KLING_API_SECRET=your_kling_api_secret_here

# === Programmatic Video ===
RENDERIO_API_KEY=your_renderio_api_key_here

# === Audio Generation ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# === Social Platforms (Legacy Direct Tokens) ===
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORG_ID=your_linkedin_org_id
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# === OAuth Client Credentials (Authorization Code Flow) ===
# Instagram Graph API OAuth
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# Facebook Graph API OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Twitter OAuth 2.0
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# YouTube (Google) OAuth 2.0
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# === Database ===
DATABASE_URL=postgresql+asyncpg://mama:mama_password@localhost:5432/mama_db
DATABASE_URL_SYNC=postgresql+psycopg://mama:mama_password@localhost:5432/mama_db

# === Cache & Queue ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === Storage ===
S3_BUCKET_NAME=mama-media-assets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# === Application ===
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change_me_in_production_use_random_256_bit_key

# === Brand Config ===
BRAND_NAME=YourBrand
BRAND_DESCRIPTION=Your brand description here
BRAND_VOICE=professional and engaging
CONTENT_GOALS=drive engagement, build brand awareness, generate leads
